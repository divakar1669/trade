# ============================================================
# Copy this to ~/.trade-cli/.env and fill in your values.
# Never commit the actual .env file.
# ============================================================

# AI layer (pick one or both — Claude is preferred)
CLAUDE_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default user when --user is not specified
DEFAULT_USER=me

# ── User: me ────────────────────────────────────────────────
ME_BROKER=angelone
ME_CLIENT_ID=AXXX123
ME_API_KEY=your-angel-one-api-key
ME_PASSWORD=your-trading-password
ME_TOTP_SECRET=BASE32TOTPSECRET

# ── User: dad ───────────────────────────────────────────────
DAD_BROKER=angelone
DAD_CLIENT_ID=BYYY456
DAD_API_KEY=dads-angel-one-api-key
DAD_PASSWORD=dads-trading-password
DAD_TOTP_SECRET=BASE32TOTPSECRET
